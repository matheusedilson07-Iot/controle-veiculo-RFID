    {
        "id": "fn_processa_evento_v2",
        "type": "function",
        "z": "tab_controle_veiculo_mqtt_v2",
        "name": "Processa evento / guarda historico",
        "func": "let events = global.get('vehicle_events') || [];\nlet stats = global.get('vehicle_stats') || {\n    total: 0,\n    autorizados: 0,\n    nao_autorizados: 0,\n    timeout: 0,\n    start_requested: 0,\n    manual_reset: 0\n};\n\nlet p = msg.payload;\n\nif (typeof p === 'string') {\n    try {\n        p = JSON.parse(p);\n    } catch (e) {\n        node.warn('Payload nao e JSON valido: ' + p);\n        return null;\n    }\n}\n\nif (!p || typeof p !== 'object') {\n    node.warn('Payload invalido');\n    return null;\n}\n\nif (!p.event_type && !p.driver_name && !p.uid && !p.timestamp) {\n    node.warn('Payload vazio ou incompleto');\n    return null;\n}\n\nlet item = {\n    datetime: p.timestamp || '',\n    device: p.device || '',\n    driver_name: p.driver_name || '',\n    uid: p.uid || '',\n    event_type: p.event_type || '',\n    status: p.status || '',\n    ip: p.ip || '',\n    timestamp_valid: p.timestamp_valid === true ? 'sim' : 'nao'\n};\nlet lastEvent = events.length > 0 ? events[events.length - 1] : null;\n\nif (\n    lastEvent &&\n    lastEvent.datetime === item.datetime &&\n    lastEvent.driver_name === item.driver_name &&\n    lastEvent.uid === item.uid &&\n    lastEvent.event_type === item.event_type &&\n    lastEvent.status === item.status\n) {\n    return null;\n}\nevents.push(item);\n\nlet now = Date.now();\nlet limit = now - (7 * 24 * 60 * 60 * 1000);\n\nevents = events.filter(e => {\n    let t = Date.parse(e.datetime);\n    if (isNaN(t)) return true;\n    return t >= limit;\n});\n\n// recalcula tudo baseado no histórico\nstats.total = events.length;\nstats.autorizados = 0;\nstats.nao_autorizados = 0;\nstats.timeout = 0;\nstats.start_requested = 0;\nstats.manual_reset = 0;\n\nfor (let e of events) {\n    switch (e.event_type) {\n        case 'authorized':\n            stats.autorizados++;\n            break;\n        case 'unauthorized_card':\n            stats.nao_autorizados++;\n            break;\n        case 'timeout':\n            stats.timeout++;\n            break;\n        case 'start_requested':\n            stats.start_requested++;\n            break;\n        case 'manual_reset':\n            stats.manual_reset++;\n            break;\n    }\n}\nglobal.set('vehicle_events', events);\nglobal.set('vehicle_stats', stats);\nglobal.set('vehicle_last_event', item);\n\nreturn [\n    { payload: events },\n    { payload: stats.total },\n    { payload: stats.autorizados },\n    { payload: stats.nao_autorizados },\n    { payload: stats.timeout },\n    { payload: item },\n    { payload: stats.start_requested },\n    { payload: stats.manual_reset }\n];",
        "outputs": 8,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 460,
        "y": 180,
        "wires": [

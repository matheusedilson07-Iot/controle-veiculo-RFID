        "id": "fn_load_history_v2",
        "type": "function",
        "z": "tab_controle_veiculo_mqtt_v2",
        "name": "Carregar historico e stats",
        "func": "let events = global.get('vehicle_events') || [];\nlet stats = global.get('vehicle_stats') || {\n    total: 0,\n    autorizados: 0,\n    nao_autorizados: 0,\n    timeout: 0,\n    start_requested: 0,\n    manual_reset: 0\n};\nlet last = global.get('vehicle_last_event') || {\n    datetime: '',\n    driver_name: '',\n    uid: '',\n    event_type: '',\n    status: '',\n    device: '',\n    ip: '',\n    timestamp_valid: ''\n};\n\nreturn [\n    { payload: events },\n    { payload: stats.total },\n    { payload: stats.autorizados },\n    { payload: stats.nao_autorizados },\n    { payload: stats.timeout },\n    { payload: last },\n    { payload: stats.start_requested },\n    { payload: stats.manual_reset }\n];",
